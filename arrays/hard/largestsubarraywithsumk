#include <bits/stdc++.h>
using namespace std;
int main() {
    int n;
    cin>>n;
    vector<int> vec(n);
    for(int i = 0 ; i < n ; i++){
        cin>>vec[i];
    }
    int sum = 0;
    int maxi = 0;
    unordered_map<int,int> mp;
    mp[0] = -1;
    for(int i = 0 ; i < n ; i++){
        sum += vec[i];
        if(mp.find(sum) != mp.end()){
            maxi = max(maxi,i - mp[sum]);
        }
        else{
            mp[sum] = i;
        }
    }
    cout<<maxi<<endl;
    return 0;
}
